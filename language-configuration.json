{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    {"open": "(", "close": ")"},
    {"open": "[", "close": "]"},
    {"open": "{", "close": "}"},
    {"open": "```", "close": "```"},
    {"open": "\"", "close": "\""},
    {"open": "'", "close": "'"}
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["```", "```"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[\\p{L}_][\\p{L}\\p{N}_]*\\s*\\([^\\)]*\\)\\s*=\\s*$"
  },
  "folding": {
    "offSide": true
  }
}

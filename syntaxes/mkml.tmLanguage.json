{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MKML",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#conversion"
    },
    {
      "include": "#uncertainty-operator"
    },
    {
      "include": "#comparison-operator"
    },
    {
      "include": "#assignment"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#units-after-numbers"
    },
    {
      "include": "#superscripts"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mkml",
          "match": "#.*$"
        }
      ]
    },
    "conversion": {
      "patterns": [
        {
          "match": "(=>|->)\\s*([a-zA-Z_][a-zA-Z0-9_\\*/\\^\\+-]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.conversion.mkml"
            },
            "2": {
              "name": "entity.name.type.class.mkml"
            }
          }
        }
      ]
    },
    "uncertainty-operator": {
      "patterns": [
        {
          "name": "keyword.operator.uncertainty.mkml",
          "match": "\\+/-|±"
        }
      ]
    },
    "comparison-operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mkml",
          "match": "=="
        }
      ]
    },
    "assignment": {
      "patterns": [
        {
          "match": "^[ \\t]*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)(?!=)",
          "captures": {
            "1": {
              "name": "variable.other.assignment.mkml"
            },
            "2": {
              "name": "keyword.operator.assignment.mkml"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mkml",
          "match": "\\*\\*|\\+|-|\\*|/|\\^|="
        },
        {
          "name": "keyword.operator.query.mkml",
          "match": "\\?"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.mkml",
          "match": "\\b\\d+\\.\\d*(?:[eE][+-]?\\d+)?\\b|\\b\\.\\d+(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.mkml",
          "match": "\\b\\d+(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "units-after-numbers": {
      "patterns": [
        {
          "match": "(?<=\\b\\d|\\b\\d\\.\\d|\\b\\d\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.class.mkml"
            }
          }
        }
      ]
    },
    "superscripts": {
      "patterns": [
        {
          "name": "string.unquoted.superscript.mkml",
          "match": "[⁻⁰¹²³⁴⁵⁶⁷⁸⁹]+"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.mkml",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.mkml"
}

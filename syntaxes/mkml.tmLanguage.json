{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MKML",
  "patterns": [
    {
      "include": "#text-blocks"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#conversion"
    },
    {
      "include": "#format-specifier"
    },
    {
      "include": "#uncertainty-operator"
    },

    {
      "include": "#comparison-operator"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#assignment"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#units-after-numbers"
    },
    {
      "include": "#superscripts"
    },
    {
      "include": "#subscripts"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "text-blocks": {
      "patterns": [
        {
          "name": "markup.raw.block.markdown.mkml",
          "begin": "```",
          "end": "```"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mkml",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mkml",
          "match": "\\b(let|in)\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.mkml",
          "match": "\\b(abs|round|floor|ceil|min|max|sqrt|sin|cos|tan|exp|log|ln)\\b(?=\\s*\\()"
        }
      ]
    },
    "conversion": {
      "patterns": [
        {
          "match": "(=>|->|<=>|⇌)\\s*([\\p{L}_][\\p{L}\\p{N}_\\*/\\^\\+-]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.conversion.mkml"
            },
            "2": {
              "name": "entity.name.type.class.mkml"
            }
          }
        }
      ]
    },
    "format-specifier": {
      "patterns": [
        {
          "match": "(:)\\s*([\\.\\p{L}\\p{N}_\\|]+)(?=\\s*\\?|\\s*$|\\s*#)",
          "captures": {
            "1": {
              "name": "punctuation.separator.delimiter.format.mkml"
            },
            "2": {
              "name": "storage.modifier.format.mkml"
            }
          }
        }
      ]
    },

    "uncertainty-operator": {
      "patterns": [
        {
          "name": "keyword.operator.uncertainty.mkml",
          "match": "\\+/-|±"
        }
      ]
    },
    "comparison-operator": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mkml",
          "match": "=="
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "^[ \\t]*([\\p{L}_][\\p{L}\\p{N}_]*)\\s*(\\([^\\)]*\\))\\s*(=)(?!=)",
          "captures": {
            "1": {
              "name": "entity.name.function.mkml"
            },
            "2": {
              "name": "variable.parameter.mkml"
            },
            "3": {
              "name": "keyword.operator.assignment.mkml"
            }
          }
        }
      ]
    },
    "assignment": {
      "patterns": [
        {
          "match": "^[ \\t]*([\\p{L}_][\\p{L}\\p{N}_]*)\\s*(=)(?!=)",
          "captures": {
            "1": {
              "name": "variable.other.assignment.mkml"
            },
            "2": {
              "name": "keyword.operator.assignment.mkml"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.mkml",
          "match": "\\*\\*|\\+|-|\\*|/|\\^|=|×|÷|√|\\|"

        },
        {
          "name": "keyword.operator.query.mkml",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.delimiter.mkml",
          "match": "[,:]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.mkml",
          "match": "\\b\\d+\\.\\d*(?:[eE][+-]?\\d+)?\\b|\\b\\.\\d+(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.mkml",
          "match": "\\b\\d+(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "units-after-numbers": {
      "patterns": [
        {
          "match": "(?<=\\b\\d|\\b\\d\\.\\d|\\b\\d\\.)\\s*([\\p{L}_][\\p{L}\\p{N}_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.class.mkml"
            }
          }
        }
      ]
    },
    "superscripts": {
      "patterns": [
        {
          "name": "string.unquoted.superscript.mkml",
          "match": "[⁻⁰¹²³⁴⁵⁶⁷⁸⁹]+"
        }
      ]
    },
    "subscripts": {
      "patterns": [
        {
          "name": "constant.numeric.subscript.mkml",
          "match": "[₀₁₂₃₄₅₆₇₈₉₋]+"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.mkml",
          "match": "\\b[\\p{L}_][\\p{L}\\p{N}_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.mkml"
}
